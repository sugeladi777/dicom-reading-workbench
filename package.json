{
  "name": "dicom-reading-workbench",
  "version": "0.1.0",
  "private": true,
  "description": "RadiAnt-style human-AI DICOM reading workbench for offline research experiments.",
  "type": "module",
  "main": "electron/main.cjs",
  "author": "OpenAI Codex",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on tcp:5173 && set WORKBENCH_DEV=1&& set ELECTRON_RUN_AS_NODE=&& electron .\"",
    "start": "set ELECTRON_RUN_AS_NODE=&& electron .",
    "build": "tsc -b && vite build",
    "pack:win": "npm run build && electron-builder --win portable",
    "preview": "vite preview",
    "verify:data": "node scripts/verify-data.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.1",
    "dicom-parser": "^1.8.21",
    "lucide-react": "^0.545.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "sql.js": "^1.13.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.7",
    "wait-on": "^8.0.4"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.openai.dicom-reading-workbench",
    "productName": "人机实验阅片工作台",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron/main.cjs"
    },
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
